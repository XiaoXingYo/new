# 1. 绝对不要传的数据集 (导致你 4GB 的元凶)
/data/
/data/data/
/data/EMNIST/
*.zip
*.ubyte

# 2. 训练产生的中间文件 (模型权重，GitHub 存不下这么多)
/checkpoints/
*.pth

# 3. 日志和可视化结果 (包含几百个坏例图片，没必要传)
/logs/
/src/logs/
/logs/bad_cases_attention/
*.log
*.png

# 4. 各种缓存和开发工具配置 (这些是你本地电脑的，别人不需要)
/.idea/
/.pytest_cache/
**/__pycache__/
*.pyc

# 5. 虚拟环境 (如果有的话)
/venv/
/.venv/